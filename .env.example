# Copy this file to .env and fill in only the providers/tools you use.
# Do not commit real API keys or private service URLs.

# Main OpenAI-compatible backbone for ARGUS investigator/profile and GPT baselines.
ARGUS_ROUTER_PROVIDER=openai-compatible
ARGUS_ROUTER_BASE_URL=https://your-openai-compatible-host/v1
ARGUS_ROUTER_API_KEY=<your-router-api-key>
ARGUS_ROUTER_MODEL=gpt-5.5
ARGUS_INVESTIGATOR_MODEL=gpt-5.5
ARGUS_VERIFIER_MODEL=gpt-5.5
ARGUS_NARRATIVE_MODEL=gpt-5.5

# Qwen / DashScope. Text defaults use Qwen3.7-Max; vision uses Qwen3.6-Plus.
DASHSCOPE_API_KEY=<your-dashscope-api-key>
ARGUS_QWEN_TEXT_MODEL=qwen3.7-max
ARGUS_QWEN_VL_MODEL=qwen3.6-plus

# Gemini / Vertex AI for difficult visual inspection.
GOOGLE_KEY_PATH=/absolute/path/to/google-service-account.json
GOOGLE_CLOUD_LOCATION=global
ARGUS_GEMINI_MODEL=gemini-3.1-pro-preview

# Optional external tools.
SERPAPI_API_KEY=<your-serpapi-key>
AMAP_API_KEY=<your-amap-key>

# Retry controls.
ARGUS_LLM_MAX_RETRIES=5
ARGUS_GEMINI_MAX_RETRIES=7
ARGUS_LLM_RETRY_BASE_INTERVAL=15

# Runtime controls.
ARGUS_TOOL_DEVICE=auto
ARGUS_SKILLS_DIR=argus/skill_adapters
ARGUS_IMAGE_CROPPER_TEMP_DIR=temp_crops
ARGUS_CACHE_DIR=outputs/argus/cache
ARGUS_DISABLE_CACHE=0
ARGUS_CONTINUE_ON_ERROR=0
ARGUS_QWEN_PERCEPTION_MAX_SIDE=768
ARGUS_QWEN_IMAGE_MAX_BYTES=1800000
ARGUS_QWEN_PAYLOAD_MAX_CHARS=24000000
ARGUS_QWEN_TEXT_ENABLE_THINKING=true
ARGUS_QWEN_VISION_ENABLE_THINKING=false
